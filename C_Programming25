#include <stdio.h>
int main()
{
    long long n;
    int digit, count = 0;
    scanf("%lld", &n);
    while (n > 0)
    {
        digit = n % 10;
        if (digit == 2 || digit == 3 || digit == 5 || digit == 7)
        {
            count++;
        }
        n = n / 10;
    }
    printf("%d", count);
    return 0;
}
