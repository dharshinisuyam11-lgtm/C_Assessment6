#include <stdio.h>
int main()
{
    int n, temp, first, last, digits = 0, p = 1, middle;
    printf("Enter a number: ");
    scanf("%d", &n);
    temp = n;
    last = n % 10;
    while (temp > 9)
    {
        temp = temp / 10;
        p = p * 10;
    }
    first = temp;
    middle = (n % p) / 10;
    n = last * p + middle * 10 + first;
    printf("After interchange = %d", n);
    return 0;
}
